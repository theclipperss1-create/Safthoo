rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the authenticated user is the authorized owner (admin)
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'gilankdev@gmail.com';
    }

    match /products/{productId} {
      allow read: if true;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['stock_qty']) ||
        isAdmin()
      );
      allow create, delete: if isAdmin();
    }
    
    // Orders: Users can create and read their own orders. Admins can read/update all orders.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Order Items: Users can create/read.
    match /order_items/{itemId} {
      allow create, read: if request.auth != null;
    }

    // Payments: Simulated payments accessible to authenticated users
    match /payments/{paymentId} {
      allow create, read, update: if request.auth != null;
    }

    // Users: Authenticated users can read/write their own profile & addresses document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Wishlists: Authenticated users can manage their own wishlist items
    match /wishlists/{wishlistId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    // Reviews: Publicly readable, authenticated creation/management with rating validation
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.product_id != null && request.resource.data.rating >= 1 && request.resource.data.rating <= 5 && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
