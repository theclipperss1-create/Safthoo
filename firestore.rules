rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow update: if request.auth != null && request.resource.data.diff(resource.data).changedKeys().hasOnly(['stock_qty']);
      allow create, delete: if false;
    }
    
    // Orders: Users can create and read their own orders.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    
    // Order Items: Users can create/read.
    match /order_items/{itemId} {
      allow create, read: if request.auth != null;
    }

    // Payments: Simulated payments accessible to authenticated users
    match /payments/{paymentId} {
      allow create, read, update: if request.auth != null;
    }

    // Users: Authenticated users can read/write their own profile & addresses document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Wishlists: Authenticated users can manage their own wishlist items
    match /wishlists/{wishlistId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
